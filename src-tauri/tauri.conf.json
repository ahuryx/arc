{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "widget-app",
  "version": "0.1.0",
  "identifier": "com.ahuryx.widget-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3001",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "controller",
        "title": "widget-app",
        "url": "index.html?role=controller",
        "visible": false,
        "width": 1,
        "height": 1,
        "skipTaskbar": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
